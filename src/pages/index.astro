---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
---

<BaseLayout title="Rolf G. Karlsson — Bird Photography">
	<header class="px-4 py-10 text-center">
		<h1 class="text-3xl font-light tracking-wide md:text-4xl">Rolf G. Karlsson</h1>
		<p class="mt-2 text-neutral-400">Bird Photography</p>
	</header>

	<section class="mx-auto max-w-3xl px-4 pb-6 text-center text-neutral-500">
		<p>Featured carousel (4–6 hand-picked birds) will go here.</p>
	</section>

	<Navbar />
</BaseLayout>
